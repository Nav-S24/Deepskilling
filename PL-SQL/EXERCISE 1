Scenario 1: 
BEGIN
    FOR rec IN (
        SELECT l.LoanID,
               l.InterestRate,
               c.DOB
        FROM Loans l
        JOIN Customers c
        ON l.CustomerID = c.CustomerID
    )
    LOOP

        IF TRUNC(MONTHS_BETWEEN(SYSDATE, rec.DOB)/12) > 60 THEN

            UPDATE Loans
            SET InterestRate = InterestRate - 1
            WHERE LoanID = rec.LoanID;

        END IF;

    END LOOP;

    COMMIT;

    DBMS_OUTPUT.PUT_LINE(
        'Discount applied successfully.'
    );

END;
